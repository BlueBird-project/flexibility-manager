# Copy this file to .env and fill in values before running docker compose.

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite: path to the database file inside containers (bind-mounted volume)
DB_PATH=/data/bb.db

# Table names (defaults match db/init.sql — only override if schema differs)
# DB_SENSORS_TABLE=measurements
# DB_FORECASTS_TABLE=disturbance_forecasts
# DB_SETPOINTS_TABLE=setpoints

# ── Flexibility Controller ────────────────────────────────────────────────────
# Path to settings.json (mounted from FlexOPTi/settings.json)
SETTINGS_FILE=/app/settings.json

# Override individual settings without editing settings.json:
# PILOT=Ewh
# SOLVER=HiGHS
# HU=48
# DELTA_T=900.0
# RETRAIN_EVERY_H=168
# HTTP_PORT=8080

# ── Trading Manager ───────────────────────────────────────────────────────────
# URL of the Trading Manager service.
# If TM is not running, fetch_prices.jl falls back to the on-disk cache.
TM_BASE_URL=http://tm-service:9090

# ── Digital Twin ──────────────────────────────────────────────────────────────
# DT_FILE is set automatically by the FC container from the shared dt-volume.
# Override only if mounting the JSON directly (e.g. bind mount for development).
# DT_FILE=/dt-volume/cold_room_model_continuous.json

# Path to R estimation script (used only when FC triggers a DT retrain subprocess)
# DT_R_SCRIPT=/dt/ctsmTMB_parameterestimation_callable.R
# DT_R_CWD=/dt

# ── Dummy Forecast service ────────────────────────────────────────────────────
# CADENCE_S=900        # seconds between forecast updates
# HORIZON_STEPS=48     # number of steps written each update
# T_AMBIENT=18.0       # constant ambient temperature [°C]
# N_ROOMS=5

# ── Control Room ──────────────────────────────────────────────────────────────
# Web dashboard at http://localhost:9000
# FC_URL=http://fc:8080
# FORECAST_URL=http://dummy-forecast:5000
# PORT=9000
