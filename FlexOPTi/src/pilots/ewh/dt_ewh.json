{
  "metadata": {
    "model_id": "ewh_cold_rooms",
    "model_type": "ctsm",
    "description": "Single-zone refrigerator thermal model",
    "version": "0.0.0",
    "sampling_time_s": 60,
    "time_unit": "seconds"
  },

  "state_space": {
    "measure_timestamp": "2026-04-01T10:30:00Z",

    "nx": 2,
    "nu": 1,
    "nd": 2,
    "ny": 1,

    "state_names":  ["T_fridge", "T_freezer1",...],
    "input_names":  ["P_compressor_fridge", ...],
    "disturbance_names": ["T_ambient", "door_open_bool",...],
    "output_names": ["T_fridge",...],

    "units": {
      "states":       ["degC", "degC",...],
      "inputs":       ["W",...],
      "disturbances": ["degC", "W/m2",...],
      "measured":     ["degC",...]
    },

    "A": [[0.9512, 0.0231], [0.0183, 0.9701]],
    "B": [[-0.0412], [-0.0089]],
    "E": [[0.0301, 0.0050], [0.0112, 0.0000]],
    "C": [[1.0, 0.0]]
  }
}